# ============================================================
# Prudent Micro Credit - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.
# ============================================================

# ------------------------------------------------------------
# EMAIL SERVICE (Resend) - https://resend.com
# ------------------------------------------------------------
# 1. Create a free account at resend.com
# 2. Go to API Keys and generate a key
# 3. Paste the real key in .env.local only, never in this example file
RESEND_API_KEY=re_your_api_key_here

# Where contact form submissions are delivered.
# Use the public business inbox, Gmail inboxes, or both.
# Separate multiple recipients with commas.
CONTACT_TO_EMAILS=info@prudentmicrocredit.com,first@gmail.com,second@gmail.com

# The "From" address shown in the received email.
# Use a sender address from the verified domain once DNS is confirmed.
CONTACT_FROM_EMAIL=info@prudentmicrocredit.com
