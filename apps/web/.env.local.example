# ============================================================
# Prudent Micro Credit — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.
# ============================================================

# ------------------------------------------------------------
# EMAIL SERVICE (Resend) — https://resend.com
# ------------------------------------------------------------
# 1. Create a free account at resend.com
# 2. Go to API Keys and generate a key
# 3. Paste it below
RESEND_API_KEY=re_your_api_key_here

# Where contact form submissions are delivered (the inbox you check)
CONTACT_TO_EMAIL=info@prudentmicrocredit.com

# The "From" address shown in the received email.
# IMPORTANT: This domain must be verified in your Resend account.
# Go to Resend > Domains > Add Domain and verify prudentmicrocredit.com.
# Until verified, use: onboarding@resend.dev (only delivers to your Resend account email)
CONTACT_FROM_EMAIL=noreply@prudentmicrocredit.com
